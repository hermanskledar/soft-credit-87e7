---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const proxyUrl = 'https://tskv-conscribo-proxy.herman-skledar.workers.dev/';
const widgets = {
  details: 'af04808317',
  events: '',
  files: 'a071d903b8',
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title="Member Portal | T.S.K.V. Spartacus" description="Manage your details, activities and files in the Spartacus member portal." />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <style>
    .portal-shell{max-width:1100px;margin:120px auto 80px;padding:0 20px}
    .panel{background:#fff;border-radius:12px;box-shadow:0 6px 20px rgba(0,0,0,.08);padding:24px}
    .intro{border-left:5px solid var(--spartacus-red);margin-bottom:20px}
    .tabs{display:flex;gap:10px;flex-wrap:wrap;margin-top:20px}
    .tab{padding:12px 16px;border:none;border-radius:10px;background:#f3f4f6;font-weight:700;cursor:pointer}
    .tab.active{background:#fff;color:var(--spartacus-burgundy);box-shadow:inset 0 -3px 0 var(--spartacus-red)}
    .pane-wrap{background:#fff;border-radius:0 12px 12px 12px;box-shadow:0 6px 20px rgba(0,0,0,.08);padding:24px;min-height:420px}
    .pane{display:none}.pane.active{display:block}
    .conscribo-app-container{min-height:260px}
  </style>
</head>
<body>
  <Header />
  <main class="portal-shell">
    <section class="panel intro">
      <h1>Spartacus Member Portal</h1>
      <p>Use the tabs below to edit your member details, view/subscribe to activities, and download files such as minutes and photos.</p>
    </section>

    <div class="tabs" role="tablist" aria-label="Portal sections">
      <button class="tab active" data-tab="details" role="tab" aria-selected="true">Member details</button>
      <button class="tab" data-tab="activities" role="tab" aria-selected="false">Activities</button>
      <button class="tab" data-tab="files" role="tab" aria-selected="false">Files</button>
    </div>

    <section class="pane-wrap">
      <article id="details-tab" class="pane active" role="tabpanel">
        <h2>Member details</h2>
        <div class="conscribo-app-container" data-id="af04808317"></div>
      </article>
      <article id="activities-tab" class="pane" role="tabpanel">
        <h2>Activities overview</h2>
        <div class="conscribo-app-container" data-page="activity_overview"></div>
      </article>
      <article id="files-tab" class="pane" role="tabpanel">
        <h2>Files</h2>
        <div class="conscribo-app-container" data-id="a071d903b8"></div>
      </article>
    </section>
  </main>
  <Footer />

  <script async src="https://leden.conscribo.nl/TSKVSpartacus/portal/loader" type="module"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = [...document.querySelectorAll('.tab')];
      const panes = [...document.querySelectorAll('.pane')];
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          tabs.forEach((t) => {
            const active = t === tab;
            t.classList.toggle('active', active);
            t.setAttribute('aria-selected', String(active));
          });
          panes.forEach((p) => p.classList.remove('active'));
          document.getElementById(`${tab.dataset.tab}-tab`)?.classList.add('active');
        });
      });
    });
  </script>
</body>
</html>
