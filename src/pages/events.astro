---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/pages/events.css';

const pageTitle = 'TSKV Spartacus events';

const apiBase = (import.meta.env.CONSCRIBO_API_BASE ?? 'https://www.conscribo.nl/api').replace(/\/$/, '');
const apiKey = import.meta.env.CONSCRIBO_API_KEY;
const clubShortCode = import.meta.env.CONSCRIBO_SHORT_CODE;

let events: Array<Record<string, unknown>> = [];
let fetchError = '';

if (!apiKey) {
  fetchError = 'Events feed is not configured yet. Please add CONSCRIBO_API_KEY to your environment variables.';
} else {
  try {
    const response = await fetch(`${apiBase}/events/`, {
      headers: {
        'Authorization': `Bearer ${apiKey}`,
        'Accept': 'application/json',
      },
    });

    if (!response.ok) {
      throw new Error(`Conscribo returned ${response.status}`);
    }

    const payload = await response.json();
    const result = payload?.results ?? payload?.data ?? payload;

    events = Array.isArray(result) ? result : [];
  } catch (error) {
    fetchError = error instanceof Error ? error.message : 'Unable to load events right now.';
  }
}

const formatDate = (value: unknown) => {
  if (typeof value !== 'string' || !value) return 'TBA';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return new Intl.DateTimeFormat('en-GB', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  }).format(date);
};

const get = (event: Record<string, unknown>, ...keys: string[]) => {
  for (const key of keys) {
    const value = event[key];
    if (value !== undefined && value !== null && value !== '') return value;
  }
  return null;
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description="Latest TSKV Spartacus events from our Conscribo planning." />
  </head>
  <body>
    <Header />
    <main class="events-page">
      <div class="container">
        <h1>TSKV Spartacus events</h1>
        <p class="events-intro">Upcoming activities, clinics and social events pulled directly from Conscribo.</p>

        {clubShortCode && (
          <p class="reservation-link">
            Looking for reservations? <a href={`https://www.conscribo.nl/events/${clubShortCode}/reservations/`} target="_blank" rel="noreferrer">Open reservations</a>
          </p>
        )}

        {fetchError ? (
          <div class="events-state error">
            <p>{fetchError}</p>
          </div>
        ) : events.length === 0 ? (
          <div class="events-state empty">
            <p>No events found at this moment. Please check back later.</p>
          </div>
        ) : (
          <section class="events-grid" aria-label="Spartacus events list">
            {events.map((event) => {
              const title = get(event, 'name', 'title', 'description') ?? 'Untitled event';
              const start = get(event, 'startDateTime', 'startDate', 'start');
              const end = get(event, 'endDateTime', 'endDate', 'end');
              const location = get(event, 'location', 'address');
              const details = get(event, 'details', 'description', 'note');

              return (
                <article class="event-card">
                  <h2>{String(title)}</h2>
                  <p><strong>Start:</strong> {formatDate(start)}</p>
                  {end && <p><strong>End:</strong> {formatDate(end)}</p>}
                  {location && <p><strong>Location:</strong> {String(location)}</p>}
                  {details && <p class="details">{String(details)}</p>}
                </article>
              );
            })}
          </section>
        )}
      </div>
    </main>
    <Footer />
  </body>
</html>
